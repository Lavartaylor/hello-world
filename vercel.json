{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/t/:slug", "destination": "/t" },
    { "source": "/t/:slug/", "destination": "/t" },
    { "source": "/tv/:slug", "destination": "/tv" },
    { "source": "/tv/:slug/", "destination": "/tv" },
    { "source": "/vote/:slug", "destination": "/vote" },
    { "source": "/vote/:slug/", "destination": "/vote" },
    { "source": "/shop/:slug", "destination": "/shop" },
    { "source": "/shop/:slug/", "destination": "/shop" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
